# ── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Raumzeit HKA ────────────────────────────────────────────────────────────
RAUMZEIT_BASE_URL=https://raumzeit.hka-iwi.de
RAUMZEIT_LOGIN=dein-hka-login
RAUMZEIT_PASSWORD=dein-hka-passwort

# ── LLM Provider ────────────────────────────────────────────────────────────
# Wähle einen Provider: claude | gemini | groq | mistral | openrouter
LLM_PROVIDER=claude

# Optional: Modell überschreiben (leer = Provider-Default)
# Beispiele:
#   claude-sonnet-4-6
#   gemini/gemini-2.0-flash
#   groq/llama-3.3-70b-versatile
#   mistral/mistral-small-latest
LLM_MODEL=

# ── API Keys (nur den gewählten Provider ausfüllen) ─────────────────────────

# Claude (console.anthropic.com)
ANTHROPIC_API_KEY=

# Gemini KOSTENLOS – aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq KOSTENLOS – console.groq.com/keys
GROQ_API_KEY=

# Mistral KOSTENLOS – console.mistral.ai/api-keys
MISTRAL_API_KEY=

# OpenRouter (teils kostenlos) – openrouter.ai/keys
OPENROUTER_API_KEY=
